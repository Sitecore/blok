{
  "name": "registry-starter",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "npm run registry:build && next dev --turbopack",
    "dev:strict": "npm run lint && npm run registry:build && next dev --turbopack",
    "build": "npm run registry:build && next build",
    "start": "next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run typecheck",
    "registry:update-urls": "npx tsx scripts/update-registry-urls.ts",
    "registry_core:build": "npx tsx scripts/build-registry.ts registries/registry-config.ts",
    "registry_marketplace_next:build": "npx tsx scripts/build-registry.ts registries/marketplace/next/registry-config.ts",
    "registry_marketplace_react:build": "npx tsx scripts/build-registry.ts registries/marketplace/react/registry-config.ts",
    "registry:build": "npm run registry:update-urls && npm run registry_core:build && npm run registry_marketplace_next:build && npm run registry_marketplace_react:build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@sitecore-marketplace-sdk/client": "^0.3.0",
    "@sitecore-marketplace-sdk/xmc": "^0.4.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lodash": ">=4.17.23",
    "lucide-react": "^0.506.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.60.0",
    "react-resizable-panels": "^3.0.3",
    "react-select": "^5.10.2",
    "recharts": "^2.15.4",
    "shiki": "^3.15.0",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@auth0/auth0-react": "^2.5.0",
    "@auth0/nextjs-auth0": "^4.10.0",
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.16.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "lodash": ">=4.17.23",
    "next": "^16.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.5",
    "typescript": "5.4.5"
  },
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "react-is": "^19.0.0-rc-69d4b800-20241021",
    "lodash": ">=4.17.23",
    "picomatch": ">=4.0.4",
    "rollup": ">=4.59.0",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.17.23",
      "picomatch": ">=4.0.4",
      "rollup": ">=4.59.0",
      "yaml": "^2.8.3"
    }
  }
}

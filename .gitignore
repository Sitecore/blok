# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Windows: tools that write log path "NUL" relative to cwd can create a real file named NUL
# (e.g. BrowserStack MCP server JSON logs); ignore so it is never committed.
/NUL

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.idea

# BrowserStack MCP credentials (copy from .cursor/mcp.json.example)
.cursor/mcp.json

# BrowserStack Local (node bindings log)
local.log
browserstack-local.log

/public/r
